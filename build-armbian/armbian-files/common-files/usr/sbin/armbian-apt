#!/bin/bash
#===========================================================================
#
# This file is licensed under the terms of the GNU General Public
# License version 2. This program is licensed "as is" without any
# warranty of any kind, whether express or implied.
#
# This file is a part of the Rebuild Armbian
# https://github.com/ophub/amlogic-s9xxx-armbian
#
# Description: Change the APT mirror source of the system
# Copyright (C) 2021- https://github.com/ophub/amlogic-s9xxx-armbian
#
# Command: armbian-apt
#
#============================= Functions list #=============================
#
# error_msg           : Output error message
# check_release       : Check the system release
# backup_source_list  : Backup the source list
# show_mirror_list    : Display the mirror list
# change_source_list  : Change the APT mirror source
# select_mirror_site  : Select the mirror site
# main                : Main entry point
#
#========================= Set default parameters ==========================
#
# Get custom firmware information
ophub_release_file="/etc/ophub-release"

# Set font color
STEPS="[\033[95m STEPS \033[0m]"
INFO="[\033[94m INFO \033[0m]"
SUCCESS="[\033[92m SUCCESS \033[0m]"
OPTIONS="[\033[93m OPTIONS \033[0m]"
ERROR="[\033[91m ERROR \033[0m]"
#
#===========================================================================

# Encountered a serious error, abort the script execution
error_msg() {
    echo -e "${ERROR} ${1}"
    exit 1
}

# Check the system release information
check_release() {
    if [[ -f "${ophub_release_file}" ]]; then
        source "${ophub_release_file}"
        VERSION_CODEID="${VERSION_CODEID}"
        VERSION_CODENAME="${VERSION_CODENAME}"
        [[ -z "${VERSION_CODEID}" ]] && error_msg "System VERSION_CODEID not detected!"
        [[ -z "${VERSION_CODENAME}" ]] && error_msg "System VERSION_CODENAME not detected!"

        # Set the source files
        armbian_source_file="/etc/apt/sources.list.d/${VERSION_CODEID}.sources"
        armbian_source_backup_file="/etc/apt/sources.list.d/${VERSION_CODEID}.sources.bak"

    else
        error_msg "System release file not found!"
    fi
}

# Backup the source list
backup_source_list() {
    # If the source file exists and the backup file does not exist, then back up the source file to the backup file
    [[ -f "${armbian_source_file}" && ! -f "${armbian_source_backup_file}" ]] && {
        cp -f "${armbian_source_file}" "${armbian_source_backup_file}"
    }

    # Disable outdated APT source files
    [[ -f "/etc/apt/sources.list" ]] && mv -f /etc/apt/sources.list /etc/apt/sources.list.bak
}

# Display the mirror list
# In certain countries or regions, the mirror hosts for Debian and Ubuntu differ and can be configured separately
show_mirror_list() {
    cat <<EOF
  ┌──────┬───────────────────┬─────────────────────────────────┐
  │  ID  │  Country/Region   │  Mirror Site                    │
  ├──────┼───────────────────┼─────────────────────────────────┤
  │   0  │  -                │  Restore default source         │
  ├──────┼───────────────────┼─────────────────────────────────┤
  │   1  │  China            │  mirrors.tuna.tsinghua.edu.cn   │
  │   2  │  China            │  mirrors.bfsu.edu.cn            │
  │   3  │  China            │  mirrors.aliyun.com             │
  │   4  │  China            │  mirrors.huaweicloud.com        │
  │   5  │  Taiwan, China    │  mirror.twds.com.tw             │
  ├──────┼───────────────────┼─────────────────────────────────┤
  │   6  │  Russia           │  mirror.yandex.ru               │
  │   7  │  South Korea      │  ftp.kaist.ac.kr                │
  │   8  │  South Korea      │  ftp.lanet.kr                   │
  │   9  │  Singapore        │  mirror.sg.gs                   │
  │  10  │  Australia        │  mirror.aarnet.edu.au           │
  ├──────┼───────────────────┼─────────────────────────────────┤
  │  11  │  United States    │  mirrors.ocf.berkeley.edu       │
  │  12  │  United States    │  files.openstack.org/mirror     │
  │  13  │  United States    │  steadfastnet.com,leaseweb.net  │
  │  14  │  Canada           │  mirror.csclub.uwaterloo.ca     │
  │  15  │  Canada           │  mirror.servercodes.com         │
  ├──────┼───────────────────┼─────────────────────────────────┤
  │  16  │  Denmark          │  ftp.openbsd.dk/mirrors         │
  │  17  │  Denmark          │  mirrors.dotsrc.org             │
  │  18  │  Germany          │  mirror.dogado.de               │
  │  19  │  Germany          │  ftp.de.debian.org,ftp.fau.de   │
  │  20  │  United Kingdom   │  mirror.yuki.net.uk             │
  └──────┴───────────────────┴─────────────────────────────────┘
EOF
}

# Change the APT mirror source
# Reference source: https://github.com/armbian/build/blob/main/lib/functions/rootfs/distro-specific.sh
change_source_list() {
    echo -e "${STEPS} Changing APT mirror source to: [ ${MIRROR_URL} ]"
    echo -e "${INFO} System release: [ ${VERSION_CODENAME} ]"

    case "${VERSION_CODENAME}" in
    buster | bullseye | bookworm | trixie | forky)
        declare -a suites=("${VERSION_CODENAME}" "${VERSION_CODENAME}-updates")
        declare -a components=(main contrib non-free)

        declare -a security_suites=()
        if [[ "${VERSION_CODENAME}" != "buster" && "${VERSION_CODENAME}" != "bullseye" ]]; then
            # EOS releases doesn't get security updates
            declare -a security_suites=("${VERSION_CODENAME}-security")
            suites+=("${VERSION_CODENAME}-backports")
            components+=("non-free-firmware")
        fi

        cat >${armbian_source_file} <<EOF
            Types: deb
            URIs: ${DEBIAN_MIRROR}
            Suites: ${suites[@]}
            Components: ${components[@]}
            Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg

EOF
        if [[ ${#security_suites[@]} -gt 0 ]]; then
            cat >>${armbian_source_file} <<EOF
            Types: deb
            URIs: ${DEBIAN_SECURITY}/
            Suites: ${security_suites[@]}
            Components: ${components[@]}
            Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg

EOF
        fi
        ;;

    resolute | focal | jammy | noble | oracular | plucky | questing)
        cat >${armbian_source_file} <<EOF
            Types: deb
            URIs: ${UBUNTU_MIRROR}/
            Suites: ${VERSION_CODENAME} ${VERSION_CODENAME}-security ${VERSION_CODENAME}-updates ${VERSION_CODENAME}-backports
            Components: main restricted universe multiverse
            Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg

EOF
        ;;

    sid | unstable)
        cat >${armbian_source_file} <<EOF
            Types: deb
            URIs: ${DEBIAN_MIRROR}/
            Suites: ${VERSION_CODENAME}
            Components: main contrib non-free non-free-firmware
            Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg

EOF
        ;;

    *)
        error_msg "Unsupported system release: [ ${VERSION_CODENAME} ]"
        ;;

    esac

    # Remove the space at the beginning of each line
    sed -i 's|^[ \t]*||' "${armbian_source_file}"
    echo -e "${SUCCESS} APT mirror source changed successfully."
}

# Select the mirror site
select_mirror_site() {
    source_id="${1}"
    echo -e "${INFO} Selected mirror source ID: [ ${source_id} ]"

    # ID 0: restore default source from backup
    if [[ "${source_id}" == "0" ]]; then
        if [[ -f "${armbian_source_backup_file}" ]]; then
            # Restore the source file from the backup file
            cp -f "${armbian_source_backup_file}" "${armbian_source_file}"
            [[ -f "/etc/apt/sources.list.bak" ]] && cp -f /etc/apt/sources.list.bak /etc/apt/sources.list

            echo -e "${SUCCESS} Default source restored successfully."
            exit 0
        else
            error_msg "Default source backup file not found."
        fi
    fi

    # Look up MIRROR_URL from show_mirror_list table by matching the ID column
    # Strip all spaces from the table, then locate the row starting with │${source_id}│
    # and take the third field (the mirror site host) as MIRROR_URL
    MIRROR_URL="$(show_mirror_list | tr -d ' ' | grep "^│${source_id}│" | awk -F '│' '{print $4}')"
    [[ -z "${MIRROR_URL}" ]] && error_msg "Invalid mirror source ID."

    # Compose the three repository URLs from the selected mirror host
    DEBIAN_MIRROR="http://${MIRROR_URL}/debian"
    DEBIAN_SECURITY="http://${MIRROR_URL}/debian-security"
    UBUNTU_MIRROR="http://${MIRROR_URL}/ubuntu-ports"

    # Configure Debian and Ubuntu mirror sources separately for certain countries/regions
    case "${source_id}" in
    13)
        DEBIAN_MIRROR="https://mirror.steadfastnet.com/debian"
        DEBIAN_SECURITY="https://mirror.steadfastnet.com/debian-security"
        UBUNTU_MIRROR="https://mirror.us.leaseweb.net/ubuntu-ports"
        ;;
    19)
        DEBIAN_MIRROR="http://ftp.de.debian.org/debian"
        DEBIAN_SECURITY="http://ftp.de.debian.org/debian-security"
        UBUNTU_MIRROR="https://ftp.fau.de/ubuntu-ports"
        ;;
    esac

    # Change the source list
    change_source_list
}

# Main entry point
main() {
    echo -e "${STEPS} Welcome to the APT Mirror Source Switching Tool."
    # Check the system release information
    check_release
    # Backup the source list
    backup_source_list

    # Prompt the user to input the source ID
    echo -e "${INFO} Please select a [\033[92m ${VERSION_CODENAME} \033[0m] mirror site."
    show_mirror_list
    echo -ne "${OPTIONS} Please Input ID: "
    read mwid

    # Validate the input and select the mirror site
    case "${mwid}" in
    [0-9]*)
        select_mirror_site "${mwid}"
        ;;
    *)
        error_msg "Invalid input."
        ;;
    esac
}

main "${@}"
